[Unit]
Description=NewsLens FastAPI backend service
After=network.target

[Service]
Type=simple
User=newslens
Group=newslens
WorkingDirectory=/srv/newslens/app
EnvironmentFile=/etc/newslens/newslens.env
Environment=NLTK_DATA=/srv/newslens/nltk_data
ExecStart=/srv/newslens/venv/bin/uvicorn \
    src.api.fastapi_app:app \
    --host 127.0.0.1 \
    --port 9000 \
    --workers 1
Restart=always
RestartSec=5
TimeoutStartSec=30
TimeoutStopSec=10
KillMode=mixed

[Install]
WantedBy=multi-user.target
