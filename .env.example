RSS_DAILY_JSON_URL=https://raw.githubusercontent.com/Distinction-Projects/RSS_Feeds/main/data/processed/rss_openai_precomputed.json
RSS_HISTORY_JSON_URL_TEMPLATE=https://raw.githubusercontent.com/Distinction-Projects/RSS_Feeds/main/data/history/rss_openai_daily_{date}.json
RSS_CACHE_TTL_SECONDS=3600
RSS_HTTP_TIMEOUT_SECONDS=20
RSS_MAX_AGE_SECONDS=129600
RSS_SOURCE_EFFECT_PERMUTATIONS=20
NEWS_EVENT_EMBEDDINGS_ENABLED=true
NEWS_EVENT_EMBEDDING_MODEL=text-embedding-3-small
NEWS_EVENT_EMBEDDING_DIMENSIONS=512
NEWS_EVENT_SIMILARITY_THRESHOLD=0.86
NEWS_EVENT_DATE_WINDOW_DAYS=3
NEWS_EVENT_EMBEDDING_CACHE_PATH=data/cache/news_event_embeddings.sqlite
NEWS_EVENT_EMBEDDING_BATCH_SIZE=128
OPENAI_API_KEY=
# News API read backend. Use "json" until migrations/imports are verified, then "postgres".
NEWS_DATA_BACKEND=json
NEWS_DB_CACHE_TTL_SECONDS=300
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# Server-only: used by FastAPI persistence and RSS-to-Postgres import jobs.
# Do not expose DATABASE_URL or service-role credentials to browser code.
# Optional aliases supported by src/services/database.py
SUPABASE_DB_URL=
SUPABASE_DIRECT_DB_URL=
SUPABASE_DIRECT_CONNECT=
# Optional frontend variables used by Next.js surface when needed
NEXT_PUBLIC_NEWS_API_BASE_URL=http://127.0.0.1:9000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_NEWS_FETCH_REVALIDATE_SECONDS=300
NEXT_PUBLIC_NEWS_FETCH_TIMEOUT_MS=20000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
